<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="750.0" prefWidth="850.0" styleClass="deposit_container" stylesheets="@../../Styles/Deposit.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dunwambank.Controllers.Admin.DepositsController">
   <children>
      <VBox layoutX="15.0" layoutY="90.0" prefHeight="570.0" prefWidth="820.0">
         <children>
            <HBox alignment="CENTER" prefHeight="60.0" prefWidth="820.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Search By Payee Address:" />
                  <TextField fx:id="payeeAddress_field" styleClass="search_box" />
                  <Button fx:id="search_button" mnemonicParsing="false" prefHeight="40.0" prefWidth="119.0" text="Search" />
               </children>
            </HBox>
            <ListView fx:id="resultsListview" prefHeight="200.0" prefWidth="820.0" styleClass="results_box" />
            <VBox alignment="TOP_CENTER" prefHeight="315.0" prefWidth="100.0" styleClass="deposit_container">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Deposit Section" wrappingWidth="83.115234375" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Amount" wrappingWidth="42.755859375" />
                  <TextField fx:id="amount_field" prefHeight="25.0" prefWidth="518.0" VBox.vgrow="SOMETIMES" />
                  <Button fx:id="deposit_button" mnemonicParsing="false" prefHeight="27.0" prefWidth="138.0" text="Deposit">
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
